# n8n variables in EasyPanel.
# Replace domains and secrets before deploying.
WEBHOOK_URL=https://n8n.tudominio.com/
N8N_EDITOR_BASE_URL=https://n8n.tudominio.com/
N8N_PROTOCOL=https
N8N_HOST=n8n.tudominio.com
N8N_PORT=5678
GENERIC_TIMEZONE=Europe/Madrid
TZ=Europe/Madrid

# Generate a long random value and keep it stable across redeploys/backups.
# Example command on your own machine/VPS: openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace-with-a-long-random-secret
